<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Matthew Cruz | Portfolio</title>
  <meta name="description" content="Matthew Cruz portfolio: software, electronics, and systems projects." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="styles.css" />
</head>
<body>
  <div class="ambient-bg" aria-hidden="true">
    <div class="bg-wash"></div>
    <div class="bg-sweep bg-sweep-left"></div>
    <div class="bg-sweep bg-sweep-right"></div>
    <div class="bg-redline"></div>
    <div class="bg-center-symbol">
      <div class="sym-ring sym-ring-1"></div>
      <div class="sym-ring sym-ring-2"></div>
      <div class="sym-ring sym-ring-3"></div>
      <div class="sym-bar sym-bar-1"></div>
      <div class="sym-bar sym-bar-2"></div>
      <div class="sym-core"></div>
    </div>
    <div class="bg-mark">ALTIMIT MINE OS</div>
    <div class="bg-scanlines"></div>
  </div>

  <button class="dock-toggle glass" type="button" aria-label="Open section dock" aria-controls="section-dock" aria-expanded="false">◉</button>
  <div class="dock-backdrop" aria-hidden="true"></div>

  <main class="layout">
    <aside id="section-dock" class="dock" aria-label="Quick launch">
      <button class="dock-item active" data-target="hero" aria-label="Home">◎</button>
      <button class="dock-item" data-target="experience" aria-label="Experience">▦</button>
      <button class="dock-item" data-target="education" aria-label="Education">⌬</button>
      <button class="dock-item" data-target="links" aria-label="Links">⟢</button>
    </aside>

    <div class="content-column">
      <section id="hero" class="panel hero glass reveal">
        <div class="win-chrome"><span class="win-chrome-title">ALTIMIT MINE OS // USER.EXE</span><div class="win-chrome-btns"><span></span><span></span><span></span></div></div>
        <div class="panel-body">
        <p class="eyebrow">SYSTEM ONLINE • Tempe, AZ</p>
        <div class="hero-ascii-row">
          <pre class="ascii-name" aria-label="Matthew Cruz">`7MMM.     ,MMF'            mm     mm     `7MM                      
  MMMb    dPMM              MM     MM       MM                      
  M YM   ,M MM   ,6"Yb.   mmMMmm mmMMmm     MMpMMMb.  .gP"Ya  `7MM  `7MM  `7MM
  M  Mb  M' MM  8)   MM     MM     MM       MM    MM ,M'   Yb   MM    MM    MM
  M  YM.P'  MM   ,pm9MM     MM     MM       MM    MM 8M""""""   MM    MM    MM
  M  `YM'   MM  8M   MM     MM     MM       MM    MM YM.    ,   MM    MM    MM
.JML. `'  .JMML.`Moo9^Yo.   `Mbmo  `Mbmo  .JMML  JMML.`Mbmmd'   `MbwwwP'bwwP' 


        .g8"""bgd                                     
      .dP'     `M                                     
      dM'       ` `7Mb,od8 `7MM  `7MM  M""MMV         
      MM            MM' "'   MM    MM  '  AMV         
      MM.    `7MMF' MM       MM    MM    AMV          
      `Mb.     MM   MM       MM    MM   AMV  ,        
        `"bmmmdPY .JMML.     `Mbod"YML.AMVMMM</pre>
          <div class="profile-photo" role="img" aria-label="Matthew Cruz profile photo"></div>
        </div>
        <p class="lead">Software engineer with experience in AI quality, multilingual LLM evaluation, prompt validation, and systems operations.</p>
        <div class="status-strip" aria-label="System status">
          <span>NODE: ACTIVE</span>
          <span>DISCIPLINE: AI + SOFTWARE</span>
          <span>MODE: SEEKING OPPORTUNITIES</span>
        </div>
        </div>
      </section>

      <section id="experience" class="panel glass reveal">
        <div class="win-chrome"><span class="win-chrome-title">ALTIMIT MINE OS // WORK_HISTORY.LOG</span><div class="win-chrome-btns"><span></span><span></span><span></span></div></div>
        <div class="panel-body">
        <div class="panel-header">
          <h2>Experience</h2>
          <span class="panel-line"></span>
        </div>
        <p class="muted">Recent roles from LinkedIn.</p>
        <ol class="timeline">
          <li>
            <div class="dot"></div>
            <div>
              <h3><span class="company-badge badge-alignerr" aria-hidden="true"><img class="company-logo" src="assets/logo-alignerr.jpg" alt="" loading="lazy" onerror="this.style.display='none'" /><span class="badge-fallback">A</span></span>Software Engineer</h3>
              <p class="meta">Alignerr · Contract</p>
              <p class="meta">Jan 2026 – Present · 4 mos</p>
              <p>Multimodal AI quality specialist in multilingual LLM evaluation (Spanish/English) and automated code review.</p>
              <p class="meta">Skill: Python</p>
            </div>
          </li>
          <li>
            <div class="dot"></div>
            <div>
              <h3><span class="company-badge badge-handshake" aria-hidden="true"><img class="company-logo" src="assets/logo-handshake.jpg" alt="" loading="lazy" onerror="this.style.display='none'" /><span class="badge-fallback">H</span></span>Data Specialist</h3>
              <p class="meta">Handshake · Contract</p>
              <p class="meta">Nov 2025 – Present · 6 mos</p>
              <p>Performing semantic validation on human-generated prompts for vision-language tasks and grounding instruction quality against visual assets.</p>
            </div>
          </li>
          <li>
            <div class="dot"></div>
            <div>
              <h3><span class="company-badge badge-amazon" aria-hidden="true"><img class="company-logo" src="assets/logo-amazon.png" alt="" loading="lazy" onerror="this.style.display='none'" /><span class="badge-fallback">a</span></span>Transportation Specialist</h3>
              <p class="meta">Amazon · Full-time</p>
              <p class="meta">Dec 2024 – Feb 2025 · 3 mos</p>
            </div>
          </li>
        </ol>
        </div>
      </section>

      <section id="education" class="panel glass reveal">
        <div class="win-chrome"><span class="win-chrome-title">ALTIMIT MINE OS // ACADEMIC_RECORDS.LOG</span><div class="win-chrome-btns"><span></span><span></span><span></span></div></div>
        <div class="panel-body">
        <div class="panel-header">
          <h2>Education</h2>
          <span class="panel-line"></span>
        </div>
        <ol class="timeline">
          <li>
            <div class="dot"></div>
            <div>
              <h3><span class="company-badge badge-asu" aria-hidden="true"><img class="company-logo" src="assets/asu-logo.png" alt="" loading="lazy" onerror="this.style.display='none'" /><span class="badge-fallback">A</span></span>Ira A. Fulton Schools of Engineering at Arizona State University</h3>
              <p class="meta">Bachelor's degree, Computer Science</p>
              <p class="meta">2023 – 2027</p>
              <p>Activities and societies: ColorStack</p>
              <p class="meta">Skills: C++, C</p>
            </div>
          </li>
          <li>
            <div class="dot"></div>
            <div>
              <h3><span class="company-badge badge-ciee" aria-hidden="true"><img class="company-logo" src="assets/ciee-logo.jpg" alt="" loading="lazy" onerror="this.style.display='none'" /><span class="badge-fallback">C</span></span>CIEE Council on International Educational Exchange</h3>
              <p class="meta">Study Abroad in South Korea</p>
              <p class="meta">Jan 2026 – Mar 2026</p>
            </div>
          </li>
        </ol>
        </div>
      </section>

      <section id="links" class="panel glass reveal">
        <div class="win-chrome"><span class="win-chrome-title">ALTIMIT MINE OS // NETWORK_LINKS.SYS</span><div class="win-chrome-btns"><span></span><span></span><span></span></div></div>
        <div class="panel-body">
        <div class="panel-header">
          <h2>Links</h2>
          <span class="panel-line"></span>
        </div>
        <ul class="link-list">
          <li><a href="https://www.linkedin.com" target="_blank" rel="noreferrer">LinkedIn</a></li>
          <li><a href="https://github.com" target="_blank" rel="noreferrer">GitHub</a></li>
        </ul>
        <footer class="site-footer">
          <a href="#hero">Home</a>
          <p>© 2026 Matthew Cruz</p>
        </footer>
        </div>
      </section>
    </div>
  </main>

  <script src="script.js"></script>
</body>
</html>
